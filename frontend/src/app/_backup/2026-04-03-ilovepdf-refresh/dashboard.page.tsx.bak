"use client";

import Link from "next/link";
import { useCallback, useEffect, useMemo, useState } from "react";
import { useSearchParams } from "next/navigation";

import AppNavbar from "@/components/AppNavbar";
import ProtectedRoute from "@/components/ProtectedRoute";
import PersonCard from "@/components/cards/PersonCard";
import LoadingSpinner from "@/components/ui/LoadingSpinner";
import Toast from "@/components/ui/Toast";
import { useAuth } from "@/context/AuthContext";
import { fetchMyFoundReports, fetchMyMissingReports } from "@/services/api";

function formatDateLabel(isoDate?: string): string {
  if (!isoDate) {
    return "Unknown time";
  }

  const date = new Date(isoDate);
  if (Number.isNaN(date.getTime())) {
    return "Unknown time";
  }

  return date.toLocaleString();
}

function containsQuery(
  values: Array<string | undefined>,
  query: string,
): boolean {
  if (!query) {
    return true;
  }

  const normalizedQuery = query.toLowerCase();
  return values.some((value) => value?.toLowerCase().includes(normalizedQuery));
}

export default function DashboardPage() {
  const searchParams = useSearchParams();
  const { token } = useAuth();
  const [loading, setLoading] = useState(true);
  const [refreshing, setRefreshing] = useState(false);
  const [error, setError] = useState("");
  const [searchTerm, setSearchTerm] = useState("");
  const [viewMode, setViewMode] = useState<"all" | "missing" | "found">("all");
  const [lastSyncedAt, setLastSyncedAt] = useState<string | null>(null);
  const [missingReports, setMissingReports] = useState<
    Awaited<ReturnType<typeof fetchMyMissingReports>>
  >([]);
  const [foundReports, setFoundReports] = useState<
    Awaited<ReturnType<typeof fetchMyFoundReports>>
  >([]);

  const loadData = useCallback(
    async (isManualRefresh = false) => {
      if (!token) {
        setError("Authentication required. Please login again.");
        setLoading(false);
        setRefreshing(false);
        return;
      }

      if (isManualRefresh) {
        setRefreshing(true);
      } else {
        setLoading(true);
      }

      setError("");
      try {
        const [missing, found] = await Promise.all([
          fetchMyMissingReports(token),
          fetchMyFoundReports(token),
        ]);
        setMissingReports(missing);
        setFoundReports(found);
        setLastSyncedAt(new Date().toISOString());
      } catch (loadError) {
        const message =
          loadError instanceof Error
            ? loadError.message
            : "Failed to load dashboard data.";
        setError(message);
      } finally {
        setLoading(false);
        setRefreshing(false);
      }
    },
    [token],
  );

  useEffect(() => {
    void loadData();
  }, [loadData]);

  useEffect(() => {
    const q = searchParams.get("q") ?? "";
    const type = searchParams.get("type");

    setSearchTerm(q);
    setViewMode(type === "missing" || type === "found" ? type : "all");
  }, [searchParams]);

  const missingPersons = useMemo(
    () =>
      missingReports.map((item) => ({
        id: item._id,
        name: item.name || "Unknown",
        age: item.age ?? undefined,
        gender: (item.gender as "Male" | "Female" | "Other") ?? undefined,
        location: item.last_seen_location ?? undefined,
        description: item.additional_info || "No additional description.",
        imageUrl: item.image_path.startsWith("http")
          ? item.image_path
          : `${process.env.NEXT_PUBLIC_API_BASE_URL ?? "http://localhost:5000"}/${item.image_path.replace(/\\/g, "/")}`,
      })),
    [missingReports],
  );

  const foundPersons = useMemo(
    () =>
      foundReports.map((item) => ({
        id: item._id,
        name: "Found Person",
        location: item.found_location ?? undefined,
        description: item.additional_info || "No additional description.",
        imageUrl: item.image_path.startsWith("http")
          ? item.image_path
          : `${process.env.NEXT_PUBLIC_API_BASE_URL ?? "http://localhost:5000"}/${item.image_path.replace(/\\/g, "/")}`,
        contact: item.contact_info ?? undefined,
      })),
    [foundReports],
  );

  const filteredMissingPersons = useMemo(
    () =>
      missingPersons.filter((person) =>
        containsQuery(
          [person.name, person.location, person.description, person.gender],
          searchTerm,
        ),
      ),
    [missingPersons, searchTerm],
  );

  const filteredFoundPersons = useMemo(
    () =>
      foundPersons.filter((person) =>
        containsQuery(
          [person.name, person.location, person.description, person.contact],
          searchTerm,
        ),
      ),
    [foundPersons, searchTerm],
  );

  const totalReports = missingPersons.length + foundPersons.length;
  const latestMissing = missingReports[0];
  const latestFound = foundReports[0];
  const recentActivity = useMemo(
    () =>
      [
        ...missingReports.map((item) => ({
          id: `missing-${item._id}`,
          title: item.name
            ? `Missing report: ${item.name}`
            : "Missing report submitted",
          subtitle: item.last_seen_location || "Location not provided",
          createdAt: item.created_at,
        })),
        ...foundReports.map((item) => ({
          id: `found-${item._id}`,
          title: "Found report submitted",
          subtitle: item.found_location || "Location not provided",
          createdAt: item.created_at,
        })),
      ]
        .sort(
          (a, b) =>
            new Date(b.createdAt).getTime() - new Date(a.createdAt).getTime(),
        )
        .slice(0, 6),
    [foundReports, missingReports],
  );

  const showMissing = viewMode === "all" || viewMode === "missing";
  const showFound = viewMode === "all" || viewMode === "found";
  const activeResultsCount =
    (showMissing ? filteredMissingPersons.length : 0) +
    (showFound ? filteredFoundPersons.length : 0);
  const hasActiveFilter = Boolean(searchTerm.trim()) || viewMode !== "all";

  return (
    <div className="min-h-screen bg-[radial-gradient(circle_at_top_right,_#dff4ff_0%,_#f7fbff_45%,_#fff7ef_100%)] text-slate-900 dark:bg-[radial-gradient(circle_at_top_right,_#102032_0%,_#0c1523_45%,_#0a121e_100%)] dark:text-slate-100">
      <AppNavbar />
      <ProtectedRoute requiredRole="user">
        <main className="mx-auto w-full max-w-7xl space-y-10 px-4 py-10 md:px-8">
          <section className="rounded-3xl border border-slate-200 bg-white/90 p-7 shadow-xl dark:border-slate-700 dark:bg-slate-900/80">
            <h1 className="text-3xl font-extrabold">Your Dashboard</h1>
            <p className="mt-2 text-sm text-slate-600 dark:text-slate-300">
              Track your missing and found reports, and continue reporting
              quickly.
            </p>
            <div className="mt-4 flex flex-wrap items-center gap-3">
              <button
                type="button"
                onClick={() => void loadData(true)}
                disabled={refreshing}
                className="rounded-lg border border-slate-300 bg-white px-3 py-1.5 text-xs font-semibold text-slate-700 transition hover:border-slate-400 hover:bg-slate-50 disabled:cursor-not-allowed disabled:opacity-60 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-200 dark:hover:border-slate-500 dark:hover:bg-slate-800"
              >
                {refreshing ? "Refreshing..." : "Refresh Data"}
              </button>
              <p className="text-xs text-slate-500 dark:text-slate-400">
                Last synced: {formatDateLabel(lastSyncedAt ?? undefined)}
              </p>
            </div>
            {error ? (
              <div className="mt-4">
                <Toast message={error} tone="error" />
              </div>
            ) : null}

            <div className="mt-6 grid gap-3 md:grid-cols-3">
              <div className="rounded-2xl border border-slate-200 bg-slate-50/80 p-4 dark:border-slate-700 dark:bg-slate-800/65">
                <p className="text-xs font-semibold uppercase tracking-[0.14em] text-slate-500 dark:text-slate-300">
                  Total Reports
                </p>
                <p className="mt-2 text-3xl font-extrabold">{totalReports}</p>
              </div>
              <div className="rounded-2xl border border-rose-200 bg-rose-50/90 p-4 dark:border-rose-800/70 dark:bg-rose-900/20">
                <p className="text-xs font-semibold uppercase tracking-[0.14em] text-rose-700 dark:text-rose-300">
                  Missing Reports
                </p>
                <p className="mt-2 text-3xl font-extrabold text-rose-700 dark:text-rose-300">
                  {missingPersons.length}
                </p>
              </div>
              <div className="rounded-2xl border border-emerald-200 bg-emerald-50/90 p-4 dark:border-emerald-800/70 dark:bg-emerald-900/20">
                <p className="text-xs font-semibold uppercase tracking-[0.14em] text-emerald-700 dark:text-emerald-300">
                  Found Reports
                </p>
                <p className="mt-2 text-3xl font-extrabold text-emerald-700 dark:text-emerald-300">
                  {foundPersons.length}
                </p>
              </div>
            </div>

            <div className="mt-6 flex flex-wrap gap-3">
              <Link
                href="/report-missing"
                className="rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-cyan-500 dark:text-slate-950 dark:hover:bg-cyan-400"
              >
                Report Missing Person
              </Link>
              <Link
                href="/report-found"
                className="rounded-full bg-slate-900 px-5 py-2.5 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-cyan-500 dark:text-slate-950 dark:hover:bg-cyan-400"
              >
                Report Found Person
              </Link>
            </div>

            {hasActiveFilter ? (
              <p className="mt-3 text-sm text-slate-600 dark:text-slate-300">
                Showing {activeResultsCount} result
                {activeResultsCount === 1 ? "" : "s"}
                {searchTerm.trim() ? ` for "${searchTerm.trim()}"` : ""}
                {viewMode !== "all"
                  ? ` in ${viewMode === "missing" ? "Missing" : "Found"}`
                  : ""}
                .
              </p>
            ) : null}
          </section>

          {loading ? (
            <div className="flex min-h-[30vh] items-center justify-center">
              <LoadingSpinner label="Loading dashboard..." />
            </div>
          ) : (
            <>
              {showMissing ? (
                <section>
                  <div className="mb-4 flex items-center justify-between">
                    <h2 className="text-xl font-bold">Your Missing Reports</h2>
                    <span className="rounded-full bg-rose-100 px-3 py-1 text-xs font-semibold text-rose-700 dark:bg-rose-900/30 dark:text-rose-300">
                      {filteredMissingPersons.length} shown /{" "}
                      {missingPersons.length} submitted
                    </span>
                  </div>
                  {filteredMissingPersons.length ? (
                    <div className="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
                      {filteredMissingPersons.map((person) => (
                        <PersonCard key={person.id} person={person} />
                      ))}
                    </div>
                  ) : (
                    <div className="rounded-2xl border border-slate-200 bg-white/80 p-5 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-300">
                      {missingPersons.length
                        ? "No missing reports match your search."
                        : "No missing reports yet. Submit your first case to start AI matching."}
                    </div>
                  )}
                </section>
              ) : null}

              {showFound ? (
                <section>
                  <div className="mb-4 flex items-center justify-between">
                    <h2 className="text-xl font-bold">Your Found Reports</h2>
                    <span className="rounded-full bg-emerald-100 px-3 py-1 text-xs font-semibold text-emerald-700 dark:bg-emerald-900/30 dark:text-emerald-300">
                      {filteredFoundPersons.length} shown /{" "}
                      {foundPersons.length} submitted
                    </span>
                  </div>
                  {filteredFoundPersons.length ? (
                    <div className="grid grid-cols-1 gap-4 md:grid-cols-2 xl:grid-cols-3">
                      {filteredFoundPersons.map((person) => (
                        <PersonCard key={person.id} person={person} />
                      ))}
                    </div>
                  ) : (
                    <div className="rounded-2xl border border-slate-200 bg-white/80 p-5 text-sm text-slate-600 dark:border-slate-700 dark:bg-slate-900/70 dark:text-slate-300">
                      {foundPersons.length
                        ? "No found reports match your search."
                        : "No found reports yet. Add a found-person report to trigger AI comparison."}
                    </div>
                  )}
                </section>
              ) : null}

              <section className="grid gap-4 lg:grid-cols-2">
                <div className="rounded-2xl border border-slate-200 bg-white/85 p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900/70">
                  <h3 className="text-lg font-bold">Recent Activity</h3>
                  {recentActivity.length ? (
                    <ul className="mt-4 space-y-3">
                      {recentActivity.map((activity) => (
                        <li
                          key={activity.id}
                          className="rounded-xl border border-slate-200 bg-slate-50/75 p-3 dark:border-slate-700 dark:bg-slate-800/65"
                        >
                          <p className="text-sm font-semibold text-slate-900 dark:text-slate-100">
                            {activity.title}
                          </p>
                          <p className="mt-1 text-xs text-slate-600 dark:text-slate-300">
                            {activity.subtitle}
                          </p>
                          <p className="mt-1 text-[11px] text-slate-500 dark:text-slate-400">
                            {formatDateLabel(activity.createdAt)}
                          </p>
                        </li>
                      ))}
                    </ul>
                  ) : (
                    <p className="mt-3 text-sm text-slate-600 dark:text-slate-300">
                      Activity will appear here once you submit reports.
                    </p>
                  )}
                </div>

                <div className="rounded-2xl border border-amber-200 bg-amber-50/85 p-5 shadow-sm dark:border-amber-800/70 dark:bg-amber-900/25">
                  <h3 className="text-lg font-bold text-amber-800 dark:text-amber-200">
                    Matching Alerts
                  </h3>
                  <p className="mt-3 text-sm text-amber-800/90 dark:text-amber-200/90">
                    Detailed AI alert feed is available in the authority
                    workflow. Your submitted reports still participate in
                    matching automatically.
                  </p>
                  <p className="mt-3 text-xs text-amber-700 dark:text-amber-300">
                    Latest missing report ID: {latestMissing?._id ?? "N/A"}
                  </p>
                  <p className="mt-1 text-xs text-amber-700 dark:text-amber-300">
                    Latest found report ID: {latestFound?._id ?? "N/A"}
                  </p>
                </div>
              </section>
            </>
          )}
        </main>
      </ProtectedRoute>
    </div>
  );
}
