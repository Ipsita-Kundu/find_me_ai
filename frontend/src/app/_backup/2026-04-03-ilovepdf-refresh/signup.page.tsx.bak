"use client";

import { FormEvent, useCallback, useEffect, useRef, useState } from "react";
import Link from "next/link";
import { useRouter } from "next/navigation";
import Script from "next/script";

import AppNavbar from "@/components/AppNavbar";
import Button from "@/components/ui/Button";
import { InputField } from "@/components/ui/FormFields";
import LoadingSpinner from "@/components/ui/LoadingSpinner";
import Toast from "@/components/ui/Toast";
import { useAuth } from "@/context/AuthContext";

function getPasswordStrength(password: string): {
  label: "Weak" | "Medium" | "Strong";
  className: string;
} {
  const hasLetters = /[A-Za-z]/.test(password);
  const hasNumbers = /\d/.test(password);
  const hasSymbols = /[^A-Za-z0-9]/.test(password);

  if (password.length >= 10 && hasLetters && hasNumbers && hasSymbols) {
    return {
      label: "Strong",
      className: "text-emerald-600 dark:text-emerald-400",
    };
  }

  if (password.length >= 8 && hasLetters && hasNumbers) {
    return { label: "Medium", className: "text-amber-600 dark:text-amber-400" };
  }

  return { label: "Weak", className: "text-rose-600 dark:text-rose-400" };
}

export default function SignupPage() {
  const router = useRouter();
  const { signup, loginWithGoogleToken } = useAuth();

  const [name, setName] = useState("");
  const [email, setEmail] = useState("");
  const [phoneNumber, setPhoneNumber] = useState("");
  const [password, setPassword] = useState("");
  const [googleLoading, setGoogleLoading] = useState(false);
  const [role, setRole] = useState<"user" | "authority">(() => {
    if (typeof window === "undefined") {
      return "user";
    }
    return new URLSearchParams(window.location.search).get("role") ===
      "authority"
      ? "authority"
      : "user";
  });
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState("");
  const [submitted, setSubmitted] = useState(false);
  const googleClientId = process.env.NEXT_PUBLIC_GOOGLE_CLIENT_ID;
  const googleRenderKeyRef = useRef("");

  const normalizedName = name.trim();
  const normalizedEmail = email.trim().toLowerCase();
  const normalizedPhone = phoneNumber.replace(/\s+/g, "").trim();

  const nameError = !normalizedName ? "Name is required." : "";
  const emailError = !normalizedEmail
    ? "Email is required."
    : !/^\S+@\S+\.\S+$/.test(normalizedEmail)
      ? "Please enter a valid email address."
      : "";
  const phoneError = !normalizedPhone
    ? "Phone number is required."
    : !/^\+?[0-9]{7,15}$/.test(normalizedPhone)
      ? "Please enter a valid phone number."
      : "";
  const passwordError = !password
    ? "Password is required."
    : password.length < 6
      ? "Password must be at least 6 characters."
      : "";

  const strength = getPasswordStrength(password);
  const showStrength = password.length > 0;

  const handleSubmit = async (event: FormEvent<HTMLFormElement>) => {
    event.preventDefault();
    setError("");
    setSubmitted(true);

    if (nameError || emailError || phoneError || passwordError) {
      setError("Please fill required fields correctly.");
      return;
    }

    setLoading(true);
    try {
      const signedUpUser = await signup(
        normalizedName,
        normalizedEmail,
        normalizedPhone,
        password,
        role,
      );
      router.push(signedUpUser.role === "authority" ? "/admin" : "/dashboard");
    } catch (signupError) {
      const message =
        signupError instanceof Error
          ? signupError.message
          : "Sign up failed. Please try again.";
      setError(message);
    } finally {
      setLoading(false);
    }
  };

  const handleGoogleCredential = useCallback(
    async (credential?: string) => {
      if (!credential) {
        setError("Google sign-up failed. Please try again.");
        return;
      }

      setGoogleLoading(true);
      setError("");
      try {
        const signedInUser = await loginWithGoogleToken(credential);
        router.push(
          signedInUser.role === "authority" ? "/admin" : "/dashboard",
        );
      } catch (googleError) {
        const message =
          googleError instanceof Error
            ? googleError.message
            : "Google sign-up failed. Please try again.";
        setError(message);
      } finally {
        setGoogleLoading(false);
      }
    },
    [loginWithGoogleToken, router],
  );

  const initializeGoogleButton = useCallback(() => {
    if (!googleClientId || !window.google) {
      return;
    }

    const container = document.getElementById("google-signup-button");
    if (!container) {
      return;
    }

    container.innerHTML = "";
    window.google.accounts.id.initialize({
      client_id: googleClientId,
      callback: ({ credential }) => {
        void handleGoogleCredential(credential);
      },
    });
    const isDarkTheme =
      document.documentElement.classList.contains("dark") ||
      window.matchMedia("(prefers-color-scheme: dark)").matches;
    const buttonWidth = Math.min(Math.max(container.clientWidth, 260), 420);
    const renderKey = `${isDarkTheme ? "dark" : "light"}-${buttonWidth}`;

    if (
      googleRenderKeyRef.current === renderKey &&
      container.childElementCount > 0
    ) {
      return;
    }

    container.replaceChildren();
    window.google.accounts.id.renderButton(container, {
      theme: isDarkTheme ? "filled_black" : "outline",
      size: "large",
      shape: "pill",
      text: "signup_with",
      width: buttonWidth,
    });
    googleRenderKeyRef.current = renderKey;
  }, [googleClientId, handleGoogleCredential]);

  useEffect(() => {
    initializeGoogleButton();

    const onGoogleLoaded = () => initializeGoogleButton();
    const onResize = () => initializeGoogleButton();
    const observer = new MutationObserver(() => initializeGoogleButton());

    window.addEventListener("google-loaded", onGoogleLoaded);
    window.addEventListener("resize", onResize);
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    return () => {
      window.removeEventListener("google-loaded", onGoogleLoaded);
      window.removeEventListener("resize", onResize);
      observer.disconnect();
    };
  }, [initializeGoogleButton]);

  return (
    <div className="min-h-screen bg-[radial-gradient(circle_at_top_right,_#dff4ff_0%,_#f7fbff_45%,_#fff7ef_100%)] text-slate-900 dark:bg-[radial-gradient(circle_at_top_right,_#102032_0%,_#0c1523_45%,_#0a121e_100%)] dark:text-slate-100">
      <Script
        src="https://accounts.google.com/gsi/client"
        strategy="afterInteractive"
        onLoad={() => window.dispatchEvent(new Event("google-loaded"))}
      />
      <AppNavbar />
      <main className="mx-auto grid w-full max-w-7xl gap-8 px-4 py-10 md:grid-cols-[0.95fr_1.05fr] md:px-8">
        <section className="rounded-3xl border border-slate-200 bg-white/85 p-7 shadow-xl dark:border-slate-700 dark:bg-slate-900/80">
          <p className="text-xs font-semibold uppercase tracking-[0.18em] text-cyan-700 dark:text-cyan-300">
            Create Account
          </p>
          <h1 className="mt-2 text-3xl font-extrabold">Create Your Account</h1>
          <p className="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
            Choose your role to access the right tools and dashboards.
          </p>

          <div className="mt-6 grid gap-3">
            <button
              type="button"
              onClick={() => setRole("user")}
              className={`rounded-2xl border p-4 text-left transition ${role === "user" ? "border-slate-900 bg-slate-900 text-white dark:border-cyan-500 dark:bg-cyan-500 dark:text-slate-950" : "border-slate-200 bg-white hover:border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-slate-500"}`}
            >
              <p className="text-sm font-bold">Normal User</p>
              <p
                className={`mt-1 text-xs ${role === "user" ? "text-slate-200 dark:text-slate-900" : "text-slate-600 dark:text-slate-300"}`}
              >
                Submit missing/found reports and monitor your cases.
              </p>
            </button>

            <button
              type="button"
              onClick={() => setRole("authority")}
              className={`rounded-2xl border p-4 text-left transition ${role === "authority" ? "border-cyan-700 bg-cyan-700 text-white dark:border-cyan-500 dark:bg-cyan-500 dark:text-slate-950" : "border-slate-200 bg-white hover:border-slate-300 dark:border-slate-700 dark:bg-slate-900 dark:hover:border-slate-500"}`}
            >
              <p className="text-sm font-bold">Authority</p>
              <p
                className={`mt-1 text-xs ${role === "authority" ? "text-cyan-100 dark:text-slate-900" : "text-slate-600 dark:text-slate-300"}`}
              >
                Access command dashboard and alert management.
              </p>
            </button>
          </div>
        </section>

        <section className="rounded-3xl border border-slate-200 bg-white/90 p-7 shadow-xl dark:border-slate-700 dark:bg-slate-900/85">
          <h2 className="text-2xl font-extrabold text-slate-900 dark:text-slate-100">
            Sign Up
          </h2>
          <p className="mt-2 text-sm text-slate-600 dark:text-slate-300">
            Enter your details to continue as a {role}.
          </p>

          <form onSubmit={handleSubmit} className="mt-6 space-y-4">
            <div className="space-y-1.5">
              <InputField
                id="name"
                label="Full Name"
                type="text"
                placeholder="Enter your full name"
                autoComplete="name"
                value={name}
                onChange={(e) => setName(e.target.value)}
                required
              />
              <p className="min-h-4 text-xs text-rose-600 dark:text-rose-400">
                {submitted && nameError ? nameError : ""}
              </p>
            </div>

            <div className="space-y-1.5">
              <InputField
                id="email"
                label="Email"
                type="email"
                placeholder="name@example.com"
                autoComplete="email"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
              <p className="min-h-4 text-xs text-rose-600 dark:text-rose-400">
                {submitted && emailError ? emailError : ""}
              </p>
            </div>

            <div className="space-y-1.5">
              <InputField
                id="phone"
                label="Phone Number"
                type="tel"
                placeholder="+91XXXXXXXXXX"
                autoComplete="tel"
                value={phoneNumber}
                onChange={(e) => setPhoneNumber(e.target.value)}
                required
              />
              <p className="min-h-4 text-xs text-rose-600 dark:text-rose-400">
                {submitted && phoneError ? phoneError : ""}
              </p>
            </div>

            <div className="space-y-1.5">
              <InputField
                id="password"
                label="Password"
                type="password"
                placeholder="Minimum 6 characters"
                autoComplete="new-password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
              <p
                className={`min-h-4 text-xs ${showStrength ? strength.className : "text-transparent"}`}
              >
                {showStrength
                  ? `Password strength: ${strength.label}`
                  : "Password strength:"}
              </p>
              <p className="min-h-4 text-xs text-rose-600 dark:text-rose-400">
                {submitted && passwordError ? passwordError : ""}
              </p>
            </div>

            {error ? <Toast message={error} tone="error" /> : null}

            <Button type="submit" fullWidth disabled={loading}>
              {loading ? (
                <LoadingSpinner label="Creating account..." />
              ) : (
                `Sign Up as ${role === "authority" ? "Authority" : "User"}`
              )}
            </Button>

            <div className="my-2 flex items-center gap-3">
              <div className="h-px flex-1 bg-slate-200 dark:bg-slate-700" />
              <p className="text-xs uppercase tracking-[0.18em] text-slate-400">
                Or
              </p>
              <div className="h-px flex-1 bg-slate-200 dark:bg-slate-700" />
            </div>

            {googleClientId ? (
              <div className="space-y-2">
                <div className="rounded-2xl border border-slate-200 bg-slate-50/80 p-2.5 dark:border-slate-700 dark:bg-slate-800/65">
                  <div
                    id="google-signup-button"
                    className="flex min-h-11 justify-center"
                  />
                </div>
                {googleLoading ? (
                  <div className="flex justify-center">
                    <LoadingSpinner label="Continuing with Google..." />
                  </div>
                ) : null}
              </div>
            ) : (
              <p className="text-center text-xs text-slate-500 dark:text-slate-400">
                Google sign-up is disabled. Add NEXT_PUBLIC_GOOGLE_CLIENT_ID to
                enable it.
              </p>
            )}
          </form>

          <p className="mt-5 text-sm text-slate-600 dark:text-slate-300">
            Already have an account?{" "}
            <Link
              href="/login"
              className="font-semibold text-cyan-700 hover:text-cyan-600"
            >
              Login
            </Link>
          </p>
        </section>
      </main>
    </div>
  );
}
