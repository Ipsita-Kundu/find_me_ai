"use client";

import { useEffect, useState } from "react";
import Link from "next/link";
import { useRouter } from "next/navigation";

import AppNavbar from "@/components/AppNavbar";
import LoadingSpinner from "@/components/ui/LoadingSpinner";
import { useAuth } from "@/context/AuthContext";

export default function HomePage() {
  const router = useRouter();
  const { initialized, isAuthenticated, getDefaultDashboardPath } = useAuth();
  const [redirecting, setRedirecting] = useState(false);

  useEffect(() => {
    if (!initialized || !isAuthenticated) {
      setRedirecting(false);
      return;
    }

    const currentHash =
      typeof window !== "undefined" ? window.location.hash.trim() : "";

    if (currentHash.length > 0) {
      setRedirecting(false);
      return;
    }

    setRedirecting(true);
    const timer = window.setTimeout(() => {
      router.replace(getDefaultDashboardPath());
    }, 0);

    return () => window.clearTimeout(timer);
  }, [getDefaultDashboardPath, initialized, isAuthenticated, router]);

  if (!initialized) {
    return (
      <div className="flex min-h-screen items-center justify-center bg-slate-50 dark:bg-slate-950">
        <LoadingSpinner label="Loading..." />
      </div>
    );
  }

  if (redirecting) {
    return (
      <div className="flex min-h-screen items-center justify-center bg-slate-50 dark:bg-slate-950">
        <LoadingSpinner label="Redirecting to your dashboard..." />
      </div>
    );
  }

  const features = [
    {
      id: "service-case-intake",
      title: "Report Missing Person",
      desc: "Submit missing-person details and images so matching can start immediately.",
      href: "/report-missing",
      cta: "Open Missing Form",
    },
    {
      id: "service-priority-alerts",
      title: "Report Found Person",
      desc: "Share location and evidence for found-person cases to trigger AI comparison.",
      href: "/report-found",
      cta: "Open Found Form",
    },
  ];

  const steps = [
    "Submit case details",
    "Review suggested matches",
    "Contact and follow up",
  ];

  return (
    <div
      id="home"
      className="min-h-screen bg-[linear-gradient(180deg,_#f8fbff_0%,_#f6f8fc_45%,_#ffffff_100%)] text-slate-900 dark:bg-[linear-gradient(180deg,_#070b14_0%,_#0b1220_50%,_#0e1726_100%)] dark:text-slate-100"
    >
      <AppNavbar />
      <section className="px-6 pb-20 pt-24 md:px-10 md:pt-28">
        <div className="mx-auto grid w-full max-w-7xl items-center gap-10 lg:grid-cols-[1.15fr_0.85fr]">
          <div>
            <p className="inline-flex rounded-full border border-slate-200 bg-white px-3 py-1 text-xs font-semibold uppercase tracking-[0.15em] text-slate-600 dark:border-slate-700 dark:bg-slate-900 dark:text-slate-300">
              FindMe AI
            </p>
            <h1 className="mt-5 text-4xl font-extrabold leading-tight md:text-6xl">
              Help People Get Home
              <span className="block text-cyan-700 dark:text-cyan-400">
                with Faster Case Coordination
              </span>
            </h1>
            <p className="mt-6 max-w-2xl text-base leading-relaxed text-slate-600 md:text-lg dark:text-slate-300">
              This platform helps families, volunteers, and authorities report
              cases, track updates, and review possible matches in a clear, easy
              workflow.
            </p>

            <div className="mt-8 flex flex-wrap gap-3">
              <Link
                href="/report-missing"
                className="rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-cyan-500 dark:text-slate-950 dark:hover:bg-cyan-400"
              >
                Report Missing Person
              </Link>
              <Link
                href="/report-found"
                className="rounded-xl border border-slate-300 bg-white px-5 py-3 text-sm font-semibold text-slate-800 transition hover:border-slate-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100 dark:hover:border-slate-500"
              >
                Report Found Person
              </Link>
              <Link
                href="/login"
                className="rounded-xl border border-cyan-200 bg-cyan-50 px-5 py-3 text-sm font-semibold text-cyan-800 transition hover:bg-cyan-100 dark:border-cyan-900/60 dark:bg-cyan-950/40 dark:text-cyan-300 dark:hover:bg-cyan-950/60"
              >
                Login for Authorities
              </Link>
            </div>
          </div>

          <div className="rounded-3xl border border-slate-200 bg-white p-6 shadow-sm md:p-7 dark:border-slate-700 dark:bg-slate-900/80">
            <p className="text-sm font-semibold uppercase tracking-[0.14em] text-slate-500 dark:text-slate-400">
              Quick Snapshot
            </p>
            <div className="mt-5 grid grid-cols-2 gap-3">
              {[
                { label: "Open Cases", value: "128" },
                { label: "Matches Reviewed Today", value: "31" },
                { label: "Average Review Time", value: "3.8s" },
                { label: "Confirmed Match Rate", value: "95%" },
              ].map((item) => (
                <div
                  key={item.label}
                  className="rounded-2xl border border-slate-200 bg-slate-50 p-4 dark:border-slate-700 dark:bg-slate-950/60"
                >
                  <p className="text-xl font-extrabold text-slate-900 dark:text-slate-100">
                    {item.value}
                  </p>
                  <p className="mt-1 text-xs text-slate-600 dark:text-slate-400">
                    {item.label}
                  </p>
                </div>
              ))}
            </div>
            <p className="mt-5 text-sm text-slate-600 dark:text-slate-300">
              A practical dashboard to help teams stay on top of urgent cases.
            </p>
          </div>
        </div>
      </section>

      <section
        id="services"
        className="border-y border-slate-200 bg-white/70 px-6 py-16 md:px-10 dark:border-slate-800 dark:bg-slate-900/30"
      >
        <div className="mx-auto max-w-7xl">
          <div className="mb-10 flex flex-wrap items-end justify-between gap-4">
            <h2 className="text-3xl font-extrabold md:text-4xl">Services</h2>
            <p className="max-w-xl text-slate-600 dark:text-slate-300">
              Start from the two core reporting actions used in everyday case
              intake.
            </p>
          </div>
          <div className="grid grid-cols-1 gap-4 md:grid-cols-2">
            {features.map((feature) => (
              <article
                key={feature.title}
                id={feature.id}
                className="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm dark:border-slate-700 dark:bg-slate-900"
              >
                <h3 className="text-lg font-bold text-slate-900 dark:text-slate-100">
                  {feature.title}
                </h3>
                <p className="mt-2 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
                  {feature.desc}
                </p>
                <Link
                  href={feature.href}
                  className="mt-4 inline-flex rounded-lg bg-slate-900 px-3 py-2 text-xs font-semibold text-white transition hover:bg-slate-800 dark:bg-cyan-500 dark:text-slate-950 dark:hover:bg-cyan-400"
                >
                  {feature.cta}
                </Link>
              </article>
            ))}
          </div>
        </div>
      </section>

      <section className="px-6 py-16 md:px-10">
        <div className="mx-auto max-w-7xl">
          <h2 className="text-center text-3xl font-extrabold md:text-4xl">
            How It Works
          </h2>
          <div className="mx-auto mt-10 grid max-w-4xl grid-cols-1 gap-4 md:grid-cols-3">
            {steps.map((step, idx) => (
              <div
                key={step}
                className="rounded-2xl border border-slate-200 bg-white p-6 text-center shadow-sm dark:border-slate-700 dark:bg-slate-900"
              >
                <p className="mx-auto mb-3 flex h-10 w-10 items-center justify-center rounded-full bg-cyan-100 text-sm font-extrabold text-cyan-700 dark:bg-cyan-950/60 dark:text-cyan-300">
                  {idx + 1}
                </p>
                <p className="text-sm font-semibold text-slate-800 dark:text-slate-200">
                  {step}
                </p>
              </div>
            ))}
          </div>
        </div>
      </section>

      <section id="about" className="px-6 pb-16 md:px-10">
        <div className="mx-auto grid max-w-7xl gap-6 lg:grid-cols-[1.2fr_0.8fr]">
          <div className="rounded-3xl border border-slate-200 bg-white p-7 shadow-sm dark:border-slate-700 dark:bg-slate-900">
            <h2 className="text-2xl font-extrabold md:text-3xl">
              Built for Real-World Use
            </h2>
            <p className="mt-4 leading-relaxed text-slate-600 dark:text-slate-300">
              We designed FindMe AI to be easy to use in high-pressure
              situations, while still keeping records clear and secure.
            </p>
            <div className="mt-6 grid grid-cols-2 gap-3 text-sm md:grid-cols-4">
              {[
                { label: "Role-Based Access", value: "Available" },
                { label: "Activity Logs", value: "Tracked" },
                { label: "Data Security", value: "Enabled" },
                { label: "Case Search", value: "Fast" },
              ].map((item) => (
                <div
                  key={item.label}
                  className="rounded-xl bg-slate-50 p-3 dark:bg-slate-950/60"
                >
                  <p className="font-bold text-slate-900 dark:text-slate-100">
                    {item.value}
                  </p>
                  <p className="mt-1 text-xs text-slate-600 dark:text-slate-400">
                    {item.label}
                  </p>
                </div>
              ))}
            </div>
          </div>

          <div className="rounded-3xl border border-cyan-200 bg-cyan-50 p-7 shadow-sm dark:border-cyan-900/60 dark:bg-cyan-950/30">
            <p className="text-xs font-semibold uppercase tracking-[0.14em] text-cyan-700 dark:text-cyan-300">
              Get Started
            </p>
            <h3 className="mt-3 text-2xl font-extrabold text-slate-900 dark:text-slate-100">
              Start managing cases in minutes
            </h3>
            <p className="mt-3 text-sm leading-relaxed text-slate-700 dark:text-slate-300">
              Create an account, choose your role, and begin reporting and
              tracking cases.
            </p>
            <div className="mt-6 flex flex-col gap-3">
              <Link
                href="/signup"
                className="rounded-xl bg-slate-900 px-4 py-3 text-center text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-cyan-500 dark:text-slate-950 dark:hover:bg-cyan-400"
              >
                Create Account
              </Link>
              <Link
                href="/login"
                className="rounded-xl border border-slate-300 bg-white px-4 py-3 text-center text-sm font-semibold text-slate-800 transition hover:border-slate-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100 dark:hover:border-slate-500"
              >
                Login
              </Link>
            </div>
          </div>
        </div>
      </section>

      <section id="contact" className="px-6 pb-14 md:px-10">
        <div className="mx-auto max-w-7xl rounded-3xl border border-slate-200 bg-white p-7 shadow-sm dark:border-slate-700 dark:bg-slate-900">
          <div className="grid gap-6 md:grid-cols-[1.2fr_0.8fr] md:items-center">
            <div>
              <p className="text-xs font-semibold uppercase tracking-[0.14em] text-cyan-700 dark:text-cyan-300">
                Contact Us
              </p>
              <h3 className="mt-2 text-2xl font-extrabold text-slate-900 dark:text-slate-100">
                Need help setting up your team?
              </h3>
              <p className="mt-3 text-sm leading-relaxed text-slate-600 dark:text-slate-300">
                Reach out for onboarding, training, or support with deployment.
              </p>
            </div>
            <div className="flex flex-col gap-3">
              <a
                href="mailto:team@findme.ai"
                className="rounded-xl bg-slate-900 px-4 py-3 text-center text-sm font-semibold text-white transition hover:bg-slate-800 dark:bg-cyan-500 dark:text-slate-950 dark:hover:bg-cyan-400"
              >
                team@findme.ai
              </a>
              <a
                href="tel:+910000000000"
                className="rounded-xl border border-slate-300 bg-white px-4 py-3 text-center text-sm font-semibold text-slate-800 transition hover:border-slate-400 dark:border-slate-600 dark:bg-slate-900 dark:text-slate-100 dark:hover:border-slate-500"
              >
                +91 00000 00000
              </a>
            </div>
          </div>
        </div>
      </section>

      <footer className="border-t border-slate-200 bg-white py-8 text-center text-sm text-slate-600 dark:border-slate-800 dark:bg-slate-950 dark:text-slate-400">
        <p>© {new Date().getFullYear()} FindMe AI. All rights reserved.</p>
      </footer>
    </div>
  );
}
