"use client";

import { FormEvent, useCallback, useEffect, useRef, useState } from "react";
import Link from "next/link";
import { useRouter } from "next/navigation";
import Script from "next/script";

import AppNavbar from "@/components/AppNavbar";
import Button from "@/components/ui/Button";
import { InputField } from "@/components/ui/FormFields";
import LoadingSpinner from "@/components/ui/LoadingSpinner";
import Toast from "@/components/ui/Toast";
import { useAuth } from "@/context/AuthContext";

export default function LoginPage() {
  const router = useRouter();
  const { login, loginWithGoogleToken } = useAuth();

  const [email, setEmail] = useState("");
  const [password, setPassword] = useState("");
  const [loading, setLoading] = useState(false);
  const [googleLoading, setGoogleLoading] = useState(false);
  const [error, setError] = useState("");
  const [submitted, setSubmitted] = useState(false);
  const googleClientId = process.env.NEXT_PUBLIC_GOOGLE_CLIENT_ID;
  const googleRenderKeyRef = useRef("");

  const normalizedEmail = email.trim().toLowerCase();
  const emailError = !normalizedEmail
    ? "Email is required."
    : !/^\S+@\S+\.\S+$/.test(normalizedEmail)
      ? "Please enter a valid email address."
      : "";
  const passwordError = !password ? "Password is required." : "";

  const handleSubmit = async (event: FormEvent<HTMLFormElement>) => {
    event.preventDefault();
    setError("");
    setSubmitted(true);

    if (emailError || passwordError) {
      setError("Please fill required fields correctly.");
      return;
    }

    setLoading(true);
    try {
      const signedInUser = await login(normalizedEmail, password);
      const redirect =
        new URLSearchParams(window.location.search).get("redirect") ||
        (signedInUser.role === "authority" ? "/admin" : "/dashboard");
      router.push(redirect);
    } catch (loginError) {
      const message =
        loginError instanceof Error
          ? loginError.message
          : "Login failed. Please try again.";
      setError(message);
    } finally {
      setLoading(false);
    }
  };

  const handleGoogleCredential = useCallback(
    async (credential?: string) => {
      if (!credential) {
        setError("Google sign-in failed. Please try again.");
        return;
      }

      setGoogleLoading(true);
      setError("");
      try {
        const signedInUser = await loginWithGoogleToken(credential);
        router.push(
          signedInUser.role === "authority" ? "/admin" : "/dashboard",
        );
      } catch (googleError) {
        const message =
          googleError instanceof Error
            ? googleError.message
            : "Google sign-in failed. Please try again.";
        setError(message);
      } finally {
        setGoogleLoading(false);
      }
    },
    [loginWithGoogleToken, router],
  );

  const initializeGoogleButton = useCallback(() => {
    if (!googleClientId || !window.google) {
      return;
    }

    const container = document.getElementById("google-login-button");
    if (!container) {
      return;
    }

    container.innerHTML = "";
    window.google.accounts.id.initialize({
      client_id: googleClientId,
      callback: ({ credential }) => {
        void handleGoogleCredential(credential);
      },
    });
    const isDarkTheme =
      document.documentElement.classList.contains("dark") ||
      window.matchMedia("(prefers-color-scheme: dark)").matches;
    const buttonWidth = Math.min(Math.max(container.clientWidth, 260), 420);
    const renderKey = `${isDarkTheme ? "dark" : "light"}-${buttonWidth}`;

    if (
      googleRenderKeyRef.current === renderKey &&
      container.childElementCount > 0
    ) {
      return;
    }

    container.replaceChildren();
    window.google.accounts.id.renderButton(container, {
      theme: isDarkTheme ? "filled_black" : "outline",
      size: "large",
      shape: "pill",
      text: "continue_with",
      width: buttonWidth,
    });
    googleRenderKeyRef.current = renderKey;
  }, [googleClientId, handleGoogleCredential]);

  useEffect(() => {
    initializeGoogleButton();

    const onGoogleLoaded = () => initializeGoogleButton();
    const onResize = () => initializeGoogleButton();
    const observer = new MutationObserver(() => initializeGoogleButton());

    window.addEventListener("google-loaded", onGoogleLoaded);
    window.addEventListener("resize", onResize);
    observer.observe(document.documentElement, {
      attributes: true,
      attributeFilter: ["class"],
    });

    return () => {
      window.removeEventListener("google-loaded", onGoogleLoaded);
      window.removeEventListener("resize", onResize);
      observer.disconnect();
    };
  }, [initializeGoogleButton]);

  return (
    <div className="min-h-screen bg-[radial-gradient(circle_at_top_right,_#dff4ff_0%,_#f7fbff_45%,_#fff7ef_100%)] dark:bg-[radial-gradient(circle_at_top_right,_#102032_0%,_#0c1523_45%,_#0a121e_100%)]">
      <Script
        src="https://accounts.google.com/gsi/client"
        strategy="afterInteractive"
        onLoad={() => window.dispatchEvent(new Event("google-loaded"))}
      />
      <AppNavbar />
      <main className="mx-auto grid w-full max-w-7xl gap-8 px-4 py-10 md:grid-cols-[1fr_1fr] md:px-8">
        <section className="rounded-3xl border border-slate-200 bg-gradient-to-br from-slate-900 via-slate-800 to-cyan-900 p-7 text-white shadow-xl">
          <p className="text-xs font-semibold uppercase tracking-[0.2em] text-cyan-200">
            Secure Access Portal
          </p>
          <h2 className="mt-3 text-3xl font-extrabold leading-tight">
            Welcome Back to FindMe AI
          </h2>
          <p className="mt-4 text-sm leading-relaxed text-slate-200">
            Sign in to access your dashboard and continue case operations.
          </p>
          <div className="mt-6 space-y-3 text-sm text-slate-100">
            <p>• User accounts open reporting workflows.</p>
            <p>• Authority accounts unlock command center views.</p>
            <p>• Secure session-based access for every account.</p>
          </div>
        </section>

        <section className="rounded-3xl border border-slate-200 bg-white/90 p-7 shadow-xl dark:border-slate-700 dark:bg-slate-900/85">
          <h1 className="text-2xl font-extrabold text-slate-900 dark:text-slate-100">
            Login
          </h1>
          <p className="mt-2 text-sm text-slate-600 dark:text-slate-300">
            Sign in to access reporting and dashboard features.
          </p>

          <form onSubmit={handleSubmit} className="mt-6 space-y-4">
            <div className="space-y-1.5">
              <InputField
                id="email"
                label="Email"
                type="email"
                placeholder="name@example.com"
                autoComplete="email"
                value={email}
                onChange={(e) => setEmail(e.target.value)}
                required
              />
              <p className="min-h-4 text-xs text-rose-600 dark:text-rose-400">
                {submitted && emailError ? emailError : ""}
              </p>
            </div>

            <div className="space-y-1.5">
              <InputField
                id="password"
                label="Password"
                type="password"
                placeholder="Enter your password"
                autoComplete="current-password"
                value={password}
                onChange={(e) => setPassword(e.target.value)}
                required
              />
              <p className="min-h-4 text-xs text-rose-600 dark:text-rose-400">
                {submitted && passwordError ? passwordError : ""}
              </p>
            </div>

            {error ? <Toast message={error} tone="error" /> : null}

            <Button type="submit" fullWidth disabled={loading}>
              {loading ? <LoadingSpinner label="Signing in..." /> : "Login"}
            </Button>

            <div className="my-2 flex items-center gap-3">
              <div className="h-px flex-1 bg-slate-200 dark:bg-slate-700" />
              <p className="text-xs uppercase tracking-[0.18em] text-slate-400">
                Or
              </p>
              <div className="h-px flex-1 bg-slate-200 dark:bg-slate-700" />
            </div>

            {googleClientId ? (
              <div className="space-y-2">
                <div className="rounded-2xl border border-slate-200 bg-slate-50/80 p-2.5 dark:border-slate-700 dark:bg-slate-800/65">
                  <div
                    id="google-login-button"
                    className="flex min-h-11 justify-center"
                  />
                </div>
                {googleLoading ? (
                  <div className="flex justify-center">
                    <LoadingSpinner label="Signing in with Google..." />
                  </div>
                ) : null}
              </div>
            ) : (
              <p className="text-center text-xs text-slate-500 dark:text-slate-400">
                Google sign-in is disabled. Add NEXT_PUBLIC_GOOGLE_CLIENT_ID to
                enable it.
              </p>
            )}
          </form>

          <p className="mt-5 text-sm text-slate-600 dark:text-slate-300">
            New here?{" "}
            <Link
              href="/signup"
              className="font-semibold text-cyan-700 hover:text-cyan-600"
            >
              Create an account
            </Link>
          </p>
        </section>
      </main>
    </div>
  );
}
